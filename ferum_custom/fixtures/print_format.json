  "html": "<div class=\"print-format\">\n  <h2>{{ _('Заявка на обслуживание') }}: {{ doc.name }}</h2>\n  <p><b>{{ _('Название') }}:</b> {{ doc.title }}</p>\n  <p><b>{{ _('Проект') }}:</b> {{ doc.project or '-' }}</p>\n  <p><b>{{ _('Клиент') }}:</b> {{ doc.customer or '-' }}</p>\n  <p><b>{{ _('Статус') }}:</b> {{ doc.status }}</p>\n  <hr/>\n  <div>{{ doc.description or '' }}</div>\n</div>",
