  "html": "<div class=\"print-format\">\n  <h2>{{ _('Табель учета рабочего времени') }}: {{ doc.name }}</h2>\n  <p><b>{{ _('Заявка') }}:</b> {{ doc.issue or '-' }}</p>\n  <p><b>{{ _('Дата отчёта') }}:</b> {{ doc.report_date }}</p>\n  <hr/>\n  <h4>{{ _('Выполненные работы') }}</h4>\n  <table class=\"table table-bordered\">\n    <thead>\n      <tr>\n        <th>#</th>\n        <th>{{ _('Описание') }}</th>\n        <th>{{ _('Часы') }}</th>\n        <th>{{ _('Ставка') }}</th>\n        <th>{{ _('Сумма') }}</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for i, it in enumerate(doc.work_items, start=1) %}\n      <tr>\n        <td>{{ i }}</td>\n        <td>{{ it.description }}</td>\n        <td style=\"text-align:right\">{{ it.hours or it.qty or 0 }}</td>\n        <td style=\"text-align:right\">{{ it.rate or 0 }}</td>\n        <td style=\"text-align:right\">{{ it.total or (it.rate or 0) * (it.hours or it.qty or 0) }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n    <tfoot>\n      <tr>\n        <th colspan=\"4\" style=\"text-align:right\">{{ _('Итого') }}</th>\n        <th style=\"text-align:right\">{{ doc.total_amount or 0 }}</th>\n      </tr>\n    </tfoot>\n  </table>\n</div>",
