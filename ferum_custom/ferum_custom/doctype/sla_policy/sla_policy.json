{
    "name": "SLA Policy",
    "doctype": "DocType",
    "engine": "InnoDB",
    "module": "Ferum Custom",
    "title_field": "title",
    "fields": [
        {
            "fieldname": "title",
            "fieldtype": "Data",
            "label": "Title",
            "reqd": 1,
            "unique": 1,
            "description": "A unique name for this policy, e.g., 'High Priority Emergency'."
        },
        {
            "fieldname": "priority",
            "fieldtype": "Select",
            "label": "Priority",
            "options": "Low\nMedium\nHigh",
            "reqd": 1
        },
        {
            "fieldname": "type",
            "fieldtype": "Select",
            "label": "Issue Type",
            "options": "Routine Maintenance\nEmergency",
            "reqd": 1
        },
        {
            "fieldname": "duration_hours",
            "fieldtype": "Float",
            "label": "SLA (Hours)",
            "reqd": 1,
            "description": "Time in hours to resolve the issue."
        },
        {
            "fieldname": "enabled",
            "fieldtype": "Check",
            "label": "Enabled",
            "default": "1"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        }
    ],
    "field_order": [
        "title",
        "priority",
        "type",
        "duration_hours",
        "enabled"
    ]
}