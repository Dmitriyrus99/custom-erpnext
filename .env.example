# Template environment file. Do NOT commit real secrets; run the render scripts instead.
# Secrets come from Vault/SSM and are merged via `./scripts/render_env.py --extra-file .env.secrets`.

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=erpnext
POSTGRES_USER=frappe
POSTGRES_PASSWORD=replace-with-secret
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=erpnext
DB_USER=frappe
DB_PASSWORD=replace-with-secret

# Redis endpoints (cache/queue/socketio)
REDIS_CACHE=redis://redis-cache:6379
REDIS_QUEUE=redis://redis-queue:6379
REDIS_SOCKETIO=redis://redis-socketio:6379

# Application & integrations
FERUM_ENABLE_JWT=1
FERUM_JWT_SECRET=replace-with-secret

# Telegram bot credentials (stored in secret manager)
FERUM_TELEGRAM_BOT_TOKEN=replace-with-secret
FERUM_TELEGRAM_WEBHOOK_SECRET=replace-with-secret
FERUM_TELEGRAM_DEFAULT_CHAT_ID=123456
FERUM_TELEGRAM_ADMIN_USERNAMES=ferumrus

# Google Drive/Sheets integration
FERUM_GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
FERUM_GOOGLE_DRIVE_ROOT_FOLDER_ID=replace-with-secret
FERUM_GOOGLE_SHEET_NAME=Ferum Invoices Tracker

# Monitoring & observability
SENTRY_DSN=
FERUM_SENTRY_DSN=
FRAPPE_SENTRY_DSN=
TRAEFIK_DASHBOARD_HOST=traefik.example.com
TRAEFIK_DASHBOARD_BASIC_AUTH=traefik:replace-with-htpasswd
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace-with-secret

# Metadata
FERUM_SECRET_ROTATION_SCHEDULE=weekly
