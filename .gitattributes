# Normalize line endings and make diffs predictable across OSes.
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts
*.sh text eol=lf

# Data formats
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Treat common binaries as binary (no eol conversion, no text diffs).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.tar binary
*.jar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mo binary
*.db binary
*.rdb binary

