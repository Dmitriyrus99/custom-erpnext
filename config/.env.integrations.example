# Central integrations config (shared by server + bot)
# Copy to config/.env.integrations and fill values. Optionally override locally via config/.env.local.integrations

# FRAPPE/Server JWT
FERUM_ENABLE_JWT=1
FERUM_JWT_SECRET=please_change_me_to_a_long_random_value

# Frappe base and service account for bot/portals
FERUM_FRAPPE_BASE_URL=https://example.com
FERUM_FRAPPE_USERNAME=
FERUM_FRAPPE_PASSWORD=

# Telegram bot
FERUM_TELEGRAM_BOT_TOKEN=
FERUM_TELEGRAM_WEBHOOK_URL=
FERUM_TELEGRAM_WEBHOOK_SECRET=
FERUM_BOT_TOTP_SECRET=

# Bot runtime
FERUM_VERIFY_SSL=true
FERUM_LOG_LEVEL=INFO
FERUM_PROMETHEUS_PORT=
FERUM_SENTRY_DSN=
