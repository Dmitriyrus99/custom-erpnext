{
  "name": "Service Report",
  "doctype": "DocType",
  "module": "Ferum Custom",
  "autoname": "SRPT-.####",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "company",
      "fieldtype": "Link",
      "label": "Company",
      "options": "Company",
      "reqd": 1
    },
    {
      "fieldname": "service_department",
      "fieldtype": "Link",
      "label": "Service Department",
      "options": "Service Department",
      "read_only": 1
    },
    {
      "fieldname": "service_request",
      "fieldtype": "Link",
      "label": "Service Request",
      "options": "Service Request",
      "reqd": 1
    },
    {
      "fieldname": "report_date",
      "fieldtype": "Date",
      "label": "Report Date",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nSubmitted\nApproved\nArchived\nCancelled",
      "default": "Draft"
    },
    {
      "fieldname": "total_amount",
      "fieldtype": "Currency",
      "label": "Total Amount",
      "read_only": 1
    },
    {
      "fieldname": "total_payable",
      "fieldtype": "Currency",
      "label": "Total Payable",
      "read_only": 1
    },
    {
      "fieldname": "work_items",
      "fieldtype": "Table",
      "label": "Work Items",
      "options": "Service Report Work Item"
    },
    {
      "fieldname": "documents",
      "fieldtype": "Table",
      "label": "Documents",
      "options": "Service Report Document Item"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1
    },
    {
      "role": "Project Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Service Engineer",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    },
    {
      "role": "Office Manager",
      "read": 1
    },
    {
      "role": "Chief Accountant",
      "read": 1
    },
    {
      "role": "Client",
      "read": 1
    },
    {
      "role": "Department Head",
      "read": 1
    }
  ]
}
