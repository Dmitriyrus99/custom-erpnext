# Telegram
BOT_TOKEN=
WEBHOOK_URL=https://erpclone.ferumrus.ru/tg-bot/webhook
WEBHOOK_SECRET=
MODE=webhook
PORT=8080

# Frappe (either API key/secret or username/password)
FRAPPE_BASE_URL=https://erpclone.ferumrus.ru
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
FRAPPE_USERNAME=telegram.bot@ferumrus.ru
FRAPPE_PASSWORD=
# Optional: if 2FA (TOTP) is enforced for the bot user
BOT_TOTP_SECRET=
VERIFY_SSL=true
LOG_LEVEL=INFO

# JWT feature flag must be enabled in Ferum Custom Settings on the site
# (Enable JWT Auth for API) and a JWT secret configured.
# No client-side audience needs to be set; the server issues tokens with aud=ferum.api.

# Prometheus (optional)
PROMETHEUS_PORT=9108

# Sentry (optional)
SENTRY_DSN=
